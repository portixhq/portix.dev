---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'PortixOne — the local infrastructure for web applications. One API. Every device.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · PortixOne</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="bg-grid min-h-screen bg-surface font-sans text-ink antialiased">
    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
