---
const nav = [
  { href: '/docs', label: 'Docs' },
  { href: '/learn', label: 'Learn' },
  { href: '/examples', label: 'Examples' },
  { href: '/compare', label: 'Compare' },
  { href: '/roadmap', label: 'Roadmap' },
  { href: '/blog', label: 'Blog' },
  { href: '/changelog', label: 'Changelog' },
];
---

<header class="border-b border-line bg-surface">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center">
      <img src="/wordmark.svg" alt="Portix.One" class="h-10 w-auto" />
    </a>
    <nav class="hidden gap-6 text-[13px] font-medium text-muted md:flex">
      {nav.map((item) => (
        <a href={item.href} class="transition-colors duration-150 ease-out hover:text-ink">{item.label}</a>
      ))}
    </nav>
    <a href="https://github.com/portixhq/portixone" class="btn-outline">
      GitHub
    </a>
  </div>
</header>
