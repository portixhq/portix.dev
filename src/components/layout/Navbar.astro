---
const nav = [
  { href: '#how-it-works', label: 'How it works' },
  { href: '#use-cases', label: 'Use cases' },
  { href: '#pricing', label: 'Pricing' },
  { href: '/docs', label: 'Docs' },
  { href: '/knowledge', label: 'Knowledge' },
];
---

<header class="sticky top-0 z-40 border-b border-line bg-black/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="flex items-center" aria-label="Portix.One home">
      <img src="/wordmark.svg" alt="Portix.One" class="h-[44px] w-auto" />
    </a>

    <nav class="hidden items-center gap-7 text-[13px] font-medium text-muted md:flex">
      {nav.map((item) => (
        <a href={item.href} class="transition-colors duration-150 ease-out hover:text-ink">{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/portixhq/portixone"
        class="hidden text-[13px] font-medium text-muted transition-colors duration-150 ease-out hover:text-ink sm:inline"
      >
        GitHub
      </a>
      <a href="#get-started" class="btn-primary">Get started</a>
    </div>
  </div>
</header>
