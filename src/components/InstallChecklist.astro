---
const items = [
  { key: 'sdkSelected', label: 'Install SDK' },
  { key: 'runtimeDownloaded', label: 'Download Runtime' },
  { key: 'runtimeDownloaded', label: 'Pair browser' },
  { key: 'playgroundPrinted', label: 'Print first receipt' },
];
---

<div class="mx-auto max-w-md">
  <div class="flex items-baseline justify-between">
    <p class="text-[15px] font-semibold text-ink">Your first print</p>
    <span class="checklist-eta font-mono text-[12px] text-accent2">~5:00 remaining</span>
  </div>

  <ul class="mt-5 space-y-3">
    {items.map((item, i) => (
      <li class="checklist-item flex items-center gap-3 text-[13px] text-muted" data-key={item.key} data-index={i}>
        <span class="checklist-check flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-line text-[11px] text-muted">
          ○
        </span>
        <span>{item.label}</span>
      </li>
    ))}
  </ul>

  <a
    href="https://github.com/portixhq/portixone/releases/latest"
    class="checklist-download mt-6 inline-block rounded-md border border-line px-5 py-2.5 text-[13px] font-semibold hover:border-accent"
  >
    Download Runtime
  </a>

  <p class="checklist-postinstall mt-4 text-[13px] leading-relaxed text-muted"></p>
</div>

<script>
  import { getState, getEtaLabel, markMilestone, onUpdate, type MilestoneKey } from '../lib/ttfp';

  function render() {
    const state = getState();

    document.querySelectorAll<HTMLElement>('.checklist-item').forEach((el) => {
      const key = el.dataset.key as MilestoneKey;
      const index = Number(el.dataset.index);
      // "Pair browser" (index 2) piggybacks on runtimeDownloaded — auto-trust makes
      // pairing effectively automatic once the Runtime is running on localhost.
      const isDone = index === 2 ? Boolean(state.runtimeDownloaded) : Boolean(state[key]);
      const check = el.querySelector('.checklist-check');
      if (check) check.textContent = isDone ? '✓' : '○';
      check?.classList.toggle('border-accent', isDone);
      check?.classList.toggle('text-accent', isDone);
      check?.classList.toggle('border-line', !isDone);
      el.classList.toggle('text-ink', isDone);
    });

    document.querySelectorAll<HTMLElement>('.checklist-eta').forEach((el) => {
      el.textContent = `~${getEtaLabel()}`;
    });

    document.querySelectorAll<HTMLElement>('.checklist-postinstall').forEach((el) => {
      el.textContent = state.runtimeDownloaded
        ? "You're one click away from your first print."
        : '';
    });
  }

  document.querySelector('.checklist-download')?.addEventListener('click', () => {
    markMilestone('runtimeDownloaded');
  });

  onUpdate(render);
</script>
