---
const cards = [
  { label: 'Quick Start', desc: 'From zero to your first print', href: '/docs' },
  { label: 'SDK', desc: 'Full API reference', href: '/docs' },
  { label: 'Runtime', desc: 'How the local bridge works', href: '/docs' },
  { label: 'Examples', desc: 'React, Vue, Next.js, Electron, and more', href: '/examples' },
  { label: 'Compare', desc: 'vs. browser printing and other libraries', href: '/compare' },
  { label: 'Roadmap', desc: 'What is built, what is next', href: '/roadmap' },
  { label: 'Changelog', desc: 'Every release, versioned', href: '/changelog' },
  { label: 'FAQ', desc: 'Common questions, answered', href: '/docs#faq' },
];
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
  {
    cards.map((card) => (
      <a href={card.href} class="rounded-md border border-line bg-surface p-5 hover:border-white/20">
        <p class="text-[14px] font-semibold text-ink">{card.label}</p>
        <p class="mt-1 text-[12px] leading-relaxed text-muted">{card.desc}</p>
      </a>
    ))
  }
</div>
