---
const before = ['Browser', 'Print Dialog', 'Drivers', 'Permissions', 'Silent Printing'];
const after = ['Browser', 'Portix.One', 'Printer'];
---

<div class="grid grid-cols-1 gap-10 md:grid-cols-2">
  <div class="flex flex-col items-center">
    <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">Without PortixOne</p>
    <div class="flex flex-col items-center">
      {before.map((step, i) => (
        <>
          <div class="w-52 rounded-md border border-line bg-surface px-4 py-2.5 text-center font-mono text-[13px] text-muted">
            {step}
            {i > 0 && <span class="ml-2 text-red-400">✕</span>}
          </div>
          {i < before.length - 1 && <div class="h-6 w-px bg-line"></div>}
        </>
      ))}
    </div>
  </div>

  <div class="flex flex-col items-center">
    <p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">With PortixOne</p>
    <div class="flex flex-col items-center justify-center" style="min-height: 100%;">
      {after.map((step, i) => (
        <>
          <div
            class:list={[
              'w-52 rounded-md border px-4 py-2.5 text-center font-mono text-[13px]',
              i === 1 ? 'border-accent text-ink' : 'border-line text-ink',
            ]}
          >
            {step}
            {i === after.length - 1 && <span class="ml-2 text-accent">✓</span>}
          </div>
          {i < after.length - 1 && <div class="h-6 w-px bg-line"></div>}
        </>
      ))}
    </div>
  </div>
</div>

<p class="mt-10 text-center text-[15px] font-semibold text-ink">Your application keeps being a web app.</p>
