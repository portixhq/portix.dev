---
const tabs = [
  {
    id: 'ts',
    label: 'TypeScript',
    available: true,
    code: `import { Portix } from '@portixone/sdk';

const portix = new Portix();
await portix.connect();

await portix.print({ content: 'Hello from PortixOne' });`,
  },
  {
    id: 'js',
    label: 'JavaScript',
    available: true,
    code: `import { Portix } from '@portixone/sdk';

const portix = new Portix();
await portix.connect();

await portix.print({ content: 'Hello from PortixOne' });`,
  },
  {
    id: 'py',
    label: 'Python',
    available: false,
    code: `from portixone import Portix

portix = Portix()
await portix.connect()

await portix.print(content="Hello from PortixOne")`,
  },
  {
    id: 'go',
    label: 'Go',
    available: false,
    code: `client := portix.New()
client.Connect()

client.Print(portix.PrintJob{
  Content: "Hello from PortixOne",
})`,
  },
];
---

<div class="code-tabs">
  <div class="flex gap-1" role="tablist">
    {tabs.map((tab, i) => (
      <button
        type="button"
        role="tab"
        data-tab={tab.id}
        aria-selected={i === 0 ? 'true' : 'false'}
        class:list={[
          'tab-btn rounded-t-md border border-b-0 border-line px-4 py-2 text-[13px]',
          i === 0 ? 'is-active bg-surface text-ink' : 'text-muted',
        ]}
      >
        {tab.label}
      </button>
    ))}
  </div>
  <div class="rounded-b-md rounded-tr-md border border-line bg-surface p-5">
    {tabs.map((tab, i) => (
      <pre
        data-panel={tab.id}
        class:list={['code-panel overflow-x-auto font-mono text-[13px] leading-7 text-ink', i !== 0 && 'hidden']}
      ><code set:html={tab.code
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/\b(import|from|const|await|new|def)\b/g, '<span class="text-accent2">$1</span>')}
      /></pre>
    ))}
    {tabs.some((t) => !t.available) && (
      <p class="mt-4 border-t border-line pt-3 text-[12px] text-muted">
        TypeScript and JavaScript are available today via <code class="font-mono">@portixone/sdk</code>. Python and Go
        are on the <a href="/roadmap" class="text-accent hover:underline">roadmap</a>.
      </p>
    )}
  </div>
</div>

<script>
  const buttons = document.querySelectorAll<HTMLElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.code-panel');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.tab;

      buttons.forEach((b) => {
        b.classList.remove('is-active', 'bg-surface', 'text-ink');
        b.classList.add('text-muted');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('is-active', 'bg-surface', 'text-ink');
      btn.classList.remove('text-muted');
      btn.setAttribute('aria-selected', 'true');

      panels.forEach((p) => {
        p.classList.toggle('hidden', p.dataset.panel !== id);
      });
    });
  });
</script>
