---
const languages = [
  { id: 'js', label: 'JavaScript' },
  { id: 'react', label: 'React' },
  { id: 'vue', label: 'Vue' },
  { id: 'angular', label: 'Angular' },
  { id: 'next', label: 'Next.js' },
];
const printers = [
  { id: 'thermal', label: 'Thermal' },
  { id: 'laser', label: 'Laser' },
  { id: 'epson', label: 'Epson' },
];
const protocols = [
  { id: 'escpos', label: 'ESC/POS' },
  { id: 'raw', label: 'RAW' },
];
---

<div class="wizard mx-auto max-w-2xl rounded-card border border-line bg-surface p-6 md:p-8">
  <div class="mb-6 flex items-center gap-2">
    {[0, 1, 2, 3].map((i) => (
      <div class:list={['wizard-dot h-1.5 flex-1 rounded-full', i === 0 ? 'bg-brand' : 'bg-line']} data-dot={i}></div>
    ))}
  </div>

  <div class="wizard-step" data-step="0">
    <p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-brand">Step 1 of 4</p>
    <h3 class="mb-4 text-[16px] font-semibold">Select your language</h3>
    <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
      {languages.map((l) => (
        <button type="button" class="wizard-choice rounded-btn border border-line px-4 py-3 text-[13px] text-muted transition-colors duration-150 ease-out hover:border-brand hover:text-ink" data-group="language" data-value={l.id}>
          {l.label}
        </button>
      ))}
    </div>
  </div>

  <div class="wizard-step hidden" data-step="1">
    <p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-brand">Step 2 of 4</p>
    <h3 class="mb-4 text-[16px] font-semibold">Select your printer</h3>
    <div class="grid grid-cols-3 gap-2">
      {printers.map((p) => (
        <button type="button" class="wizard-choice rounded-btn border border-line px-4 py-3 text-[13px] text-muted transition-colors duration-150 ease-out hover:border-brand hover:text-ink" data-group="printer" data-value={p.id}>
          {p.label}
        </button>
      ))}
    </div>
  </div>

  <div class="wizard-step hidden" data-step="2">
    <p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-brand">Step 3 of 4</p>
    <h3 class="mb-4 text-[16px] font-semibold">Select your protocol</h3>
    <div class="grid grid-cols-2 gap-2">
      {protocols.map((p) => (
        <button type="button" class="wizard-choice rounded-btn border border-line px-4 py-3 text-[13px] text-muted transition-colors duration-150 ease-out hover:border-brand hover:text-ink" data-group="protocol" data-value={p.id}>
          {p.label}
        </button>
      ))}
    </div>
  </div>

  <div class="wizard-step hidden" data-step="3">
    <p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-brand">Your snippet</p>
    <h3 class="mb-4 text-[16px] font-semibold">This is your integration.</h3>
    <div class="rounded-code border border-line bg-surface-tertiary p-5">
      <pre class="wizard-snippet overflow-x-auto font-mono text-[13px] leading-7 text-ink"><code></code></pre>
    </div>
    <a href="/docs" class="wizard-continue btn-primary mt-6 inline-flex">
      Continue
    </a>
  </div>

  <div class="wizard-nav mt-6 flex items-center justify-between">
    <button type="button" class="wizard-back text-[13px] text-muted hover:text-ink disabled:opacity-0" disabled>← Back</button>
    <span class="wizard-hint text-[12px] text-muted"></span>
  </div>
</div>

<script>
  import { markStage } from '../lib/ttfp';

  const wizard = document.querySelector<HTMLElement>('.wizard');
  if (wizard) {
    const steps = wizard.querySelectorAll<HTMLElement>('.wizard-step');
    const dots = wizard.querySelectorAll<HTMLElement>('.wizard-dot');
    const backBtn = wizard.querySelector<HTMLButtonElement>('.wizard-back');
    const hint = wizard.querySelector<HTMLElement>('.wizard-hint');
    const snippetCode = wizard.querySelector<HTMLElement>('.wizard-snippet code');

    const selections: Record<string, string> = {};
    let current = 0;

    // Built via concatenation, not a literal line-start match, so Vite's dev-time
    // dependency scanner doesn't mistake this *sample text* for a real import to resolve.
    const sdkPkg = '@portixone' + '/sdk';
    const importLine = `import { Portix } from '${sdkPkg}';`;

    // Maps the wizard's illustrative choices to the SDK's real PrintJob shape
    // ({ content, printerName?, copies? } — see packages/protocol/src/job.types.ts).
    // There's no `protocol` field on print(): ESC/POS vs. RAW is handled by the
    // Runtime's driver layer, not something a caller specifies per job — the
    // wizard still asks so the snippet's comment can name the printer honestly.
    const printerNames: Record<string, string> = {
      thermal: 'Thermal POS-80',
      laser: 'HP LaserJet',
      epson: 'Epson TM-T88',
    };
    const protocolNotes: Record<string, string> = {
      escpos: 'ESC/POS — handled automatically by the Runtime',
      raw: 'RAW — handled automatically by the Runtime',
    };

    function printerNameFor(printer: string): string {
      return printerNames[printer] ?? 'default';
    }
    function protocolCommentFor(protocol: string): string {
      return `// Protocol: ${protocolNotes[protocol] ?? protocol}`;
    }

    const templates: Record<string, (p: { printer: string; protocol: string }) => string> = {
      js: ({ printer, protocol }) => `${importLine}

const portix = new Portix({ appId: 'my-app', tenant: 'default' });
await portix.connect();

${protocolCommentFor(protocol)}
await portix.print({
  content: 'Hello from PortixOne',
  printerName: '${printerNameFor(printer)}',
});`,
      react: ({ printer, protocol }) => `${importLine}

const portix = new Portix({ appId: 'my-app', tenant: 'default' });

function PrintButton() {
  const handlePrint = async () => {
    await portix.connect();
    ${protocolCommentFor(protocol)}
    await portix.print({ content: 'Hello!', printerName: '${printerNameFor(printer)}' });
  };

  return <button onClick={handlePrint}>Print</button>;
}`,
      vue: ({ printer, protocol }) => `${importLine}

const portix = new Portix({ appId: 'my-app', tenant: 'default' });

async function print() {
  await portix.connect();
  ${protocolCommentFor(protocol)}
  await portix.print({ content: 'Hello!', printerName: '${printerNameFor(printer)}' });
}`,
      angular: ({ printer, protocol }) => `${importLine}

export class PrintService {
  private portix = new Portix({ appId: 'my-app', tenant: 'default' });

  async print() {
    await this.portix.connect();
    ${protocolCommentFor(protocol)}
    await this.portix.print({ content: 'Hello!', printerName: '${printerNameFor(printer)}' });
  }
}`,
      next: ({ printer, protocol }) => `'use client';
${importLine}

const portix = new Portix({ appId: 'my-app', tenant: 'default' });

export default function PrintButton() {
  const handlePrint = async () => {
    await portix.connect();
    ${protocolCommentFor(protocol)}
    await portix.print({ content: 'Hello!', printerName: '${printerNameFor(printer)}' });
  };

  return <button onClick={handlePrint}>Print</button>;
}`,
    };

    function highlight(code: string) {
      return code
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/\b(import|from|const|await|new|async|function|export|class|return)\b/g, '<span class="text-brand">$1</span>');
    }

    function showStep(i: number) {
      steps.forEach((s) => s.classList.toggle('hidden', Number(s.dataset.step) !== i));
      dots.forEach((d) => d.classList.toggle('bg-brand', Number(d.dataset.dot) <= i));
      dots.forEach((d) => d.classList.toggle('bg-line', Number(d.dataset.dot) > i));
      if (backBtn) backBtn.disabled = i === 0;
      if (hint) hint.textContent = i < 3 ? '' : '';
      current = i;
    }

    wizard.querySelectorAll<HTMLButtonElement>('.wizard-choice').forEach((btn) => {
      btn.addEventListener('click', () => {
        const group = btn.dataset.group!;
        const value = btn.dataset.value!;
        selections[group] = value;

        if (current === 2) {
          const template = templates[selections.language] ?? templates.js;
          const code = template({ printer: selections.printer ?? 'default', protocol: selections.protocol ?? 'escpos' });
          if (snippetCode) snippetCode.innerHTML = highlight(code);
          markStage('generatedSnippet');
        }

        showStep(Math.min(current + 1, 3));
      });
    });

    backBtn?.addEventListener('click', () => showStep(Math.max(current - 1, 0)));

    wizard.querySelector('.wizard-continue')?.addEventListener('click', () => {
      markStage('generatedSnippet');
    });
  }
</script>
