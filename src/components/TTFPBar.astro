<div
  class="ttfp-bar fixed inset-x-0 bottom-0 z-50 border-t border-line bg-bg/95 backdrop-blur"
  aria-live="polite"
>
  <div class="mx-auto flex max-w-6xl items-center gap-4 px-6 py-2.5">
    <span class="shrink-0 text-[11px] font-semibold uppercase tracking-[0.1em] text-muted">Time to first print</span>
    <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-white/10">
      <div class="ttfp-fill h-full w-[8%] rounded-full bg-gradient-to-r from-accent2 to-accent transition-all duration-500"></div>
    </div>
    <span class="ttfp-percent shrink-0 font-mono text-[12px] font-semibold text-ink">8%</span>
    <span class="ttfp-eta hidden shrink-0 font-mono text-[11px] text-muted sm:inline">4:36 remaining</span>
  </div>
</div>

<script>
  import { getProgress, getEtaLabel, onUpdate } from '../lib/ttfp';

  function render() {
    const percent = Math.round(getProgress());
    document.querySelectorAll<HTMLElement>('.ttfp-fill').forEach((el) => {
      el.style.width = `${percent}%`;
    });
    document.querySelectorAll<HTMLElement>('.ttfp-percent').forEach((el) => {
      el.textContent = `${percent}%`;
    });
    document.querySelectorAll<HTMLElement>('.ttfp-eta').forEach((el) => {
      el.textContent = getEtaLabel();
    });
  }

  onUpdate(render);
</script>
