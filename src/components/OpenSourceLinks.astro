---
const links = [
  { label: 'GitHub', desc: 'Source, issues, and discussions', href: 'https://github.com/portixhq/portixone' },
  { label: 'Releases', desc: 'Tagged versions with changelogs', href: 'https://github.com/portixhq/portixone/releases' },
  { label: 'Contributors', desc: 'Everyone who has shipped a line', href: 'https://github.com/portixhq/portixone/graphs/contributors' },
  { label: 'Issues', desc: 'Bugs and feature requests', href: 'https://github.com/portixhq/portixone/issues' },
  { label: 'Roadmap', desc: 'What’s built, what’s next', href: '/roadmap' },
  { label: 'Discord', desc: 'Coming soon', href: null },
];
---

<div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
  {
    links.map((link) =>
      link.href ? (
        <a href={link.href} class="rounded-md border border-line bg-surface p-5 hover:border-white/20">
          <p class="text-[14px] font-semibold text-ink">{link.label}</p>
          <p class="mt-1 text-[12px] text-muted">{link.desc}</p>
        </a>
      ) : (
        <div class="rounded-md border border-line bg-surface p-5 opacity-50">
          <p class="text-[14px] font-semibold text-ink">{link.label}</p>
          <p class="mt-1 text-[12px] text-muted">{link.desc}</p>
        </div>
      ),
    )
  }
</div>
