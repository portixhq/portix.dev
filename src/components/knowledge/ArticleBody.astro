---

<div class="knowledge-prose mt-8">
  <slot />
</div>

<style is:global>
  .knowledge-prose h2 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .knowledge-prose h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .knowledge-prose p {
    margin-top: 1rem;
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-muted);
  }
  .knowledge-prose a {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .knowledge-prose ul,
  .knowledge-prose ol {
    margin-top: 1rem;
    padding-left: 1.25rem;
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-muted);
  }
  .knowledge-prose ul {
    list-style: disc;
  }
  .knowledge-prose ol {
    list-style: decimal;
  }
  .knowledge-prose li + li {
    margin-top: 0.375rem;
  }
  .knowledge-prose blockquote {
    margin-top: 1.5rem;
    border-left: 2px solid var(--color-line-strong);
    padding-left: 1rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .knowledge-prose code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--color-ink);
  }
  .knowledge-prose pre {
    margin-top: 1.5rem;
    overflow-x: auto;
    border-radius: 14px;
    border: 1px solid var(--color-line);
    background: var(--color-surface-tertiary);
    padding: 1.25rem;
  }
  .knowledge-prose pre code {
    font-size: 13px;
    line-height: 1.75;
  }
  .knowledge-prose table {
    margin-top: 1.5rem;
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--color-line);
    border-radius: 14px;
    font-size: 13px;
  }
  .knowledge-prose th,
  .knowledge-prose td {
    border-bottom: 1px solid var(--color-line);
    padding: 0.6rem 0.9rem;
    text-align: left;
  }
  .knowledge-prose th {
    color: var(--color-muted);
    font-weight: 500;
  }
  .knowledge-prose img {
    margin-top: 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--color-line);
  }
</style>
