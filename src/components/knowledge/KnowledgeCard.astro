---
interface Props {
  href: string;
  title: string;
  description: string;
  contentType: string;
}

const { href, title, description, contentType } = Astro.props;
---

<a href={href} class="block rounded-card border border-line p-5 transition-colors duration-150 ease-out hover:border-line-strong">
  <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-brand">{contentType}</p>
  <h3 class="mt-2 font-mono text-[15px] font-semibold text-ink">{title}</h3>
  <p class="mt-2 text-[13px] leading-relaxed text-muted">{description}</p>
</a>
