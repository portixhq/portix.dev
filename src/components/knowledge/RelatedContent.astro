---
import KnowledgeCard from './KnowledgeCard.astro';
import { knowledgeEntryHref } from '../../lib/knowledge-types';

interface RelatedEntry {
  id: string;
  data: {
    title: string;
    description: string;
    contentType: string;
  };
}

interface Props {
  entries: RelatedEntry[];
}

const { entries } = Astro.props;
---

{entries.length > 0 && (
  <section class="mt-12 border-t border-line pt-8">
    <h2 class="font-mono text-lg font-semibold text-ink">Related content</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      {entries.map((entry) => (
        <KnowledgeCard
          href={knowledgeEntryHref(entry.id)}
          title={entry.data.title}
          description={entry.data.description}
          contentType={entry.data.contentType}
        />
      ))}
    </div>
  </section>
)}
