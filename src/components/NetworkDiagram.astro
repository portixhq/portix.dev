---
const nodes = [
  { x: 60, y: 50 }, { x: 200, y: 30 }, { x: 340, y: 50 },
  { x: 40, y: 180 }, { x: 360, y: 180 },
  { x: 60, y: 310 }, { x: 200, y: 330 }, { x: 340, y: 310 },
];
const center = { x: 200, y: 180 };
---

<svg
  viewBox="0 0 400 360"
  class="h-auto w-full"
  role="img"
  aria-label="Abstract network diagram of thin lines and square nodes converging on a central PortixOne node, representing the runtime's communication graph"
>
  <title>PortixOne runtime communication graph</title>
  <g stroke="rgba(255,255,255,.08)" stroke-width="1">
    {nodes.map((n) => <line x1={n.x} y1={n.y} x2={center.x} y2={center.y} />)}
  </g>
  <g fill="none" stroke="#5B8CFF" stroke-width="1.5" opacity="0.85">
    {nodes.map((n) => <rect x={n.x - 8} y={n.y - 8} width="16" height="16" />)}
  </g>
  <rect
    x={center.x - 22}
    y={center.y - 22}
    width="44"
    height="44"
    fill="#00161C"
    stroke="#00C8FF"
    stroke-width="1.5"
    transform={`rotate(45 ${center.x} ${center.y})`}
  />
</svg>
