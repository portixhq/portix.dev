---
const items = [
  { label: 'SDK Public', status: 'done' },
  { label: 'Runtime', status: 'done' },
  { label: 'Windows Installer', status: 'progress' },
  { label: 'Branding', status: 'progress' },
  { label: 'Landing', status: 'progress' },
  { label: 'Documentation', status: 'progress' },
  { label: 'Public Launch', status: 'pending' },
];

const icon: Record<string, string> = { done: '✅', progress: '🟡', pending: '⬜' };
---

<div class="flex flex-col divide-y divide-line rounded-md border border-line bg-surface">
  {
    items.map((item) => (
      <div class="flex items-center gap-3 px-5 py-3.5 text-[13px]">
        <span>{icon[item.status]}</span>
        <span class="text-ink">{item.label}</span>
      </div>
    ))
  }
</div>
