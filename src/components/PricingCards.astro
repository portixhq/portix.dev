---
const plans = [
  {
    name: 'Free',
    tagline: 'For every developer',
    price: '$0',
    features: ['Full Runtime & SDK', 'Silent printing', 'Unrestricted production use', 'Playground & docs', 'Community support'],
    cta: 'Get Started',
    href: '/docs',
    highlight: false,
  },
  {
    name: 'Production',
    tagline: 'Recommended',
    price: '$24/mo',
    features: ['Everything in Free', 'Priority support', 'Production reliability tooling'],
    cta: 'Notify Me',
    href: '#join',
    highlight: true,
  },
  {
    name: 'Scale',
    tagline: 'For growing operations',
    price: '$79/mo',
    features: ['Organizations & teams', 'Runtime health & diagnostics', 'Remote configuration', 'Version management', 'Priority support'],
    cta: 'Notify Me',
    href: '#join',
    highlight: false,
  },
];
---

<div class="grid grid-cols-1 gap-5 md:grid-cols-3">
  {
    plans.map((plan) => (
      <div
        class:list={[
          'flex flex-col rounded-card border p-6',
          plan.highlight ? 'border-brand bg-surface' : 'border-line bg-surface',
        ]}
      >
        <p class="text-[13px] font-semibold uppercase tracking-[0.1em] text-muted">{plan.name}</p>
        <p class="mt-1 font-mono text-[13px] text-brand">{plan.tagline}</p>
        <p class="mt-4 font-mono text-2xl font-bold text-ink">{plan.price}</p>
        <ul class="mt-5 flex-1 space-y-2 text-[13px] text-muted">
          {plan.features.map((f) => (
            <li class="flex gap-2">
              <span class="text-brand">✓</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href={plan.href} class:list={['mt-6 text-center', plan.highlight ? 'btn-primary' : 'btn-outline']}>
          {plan.cta}
        </a>
      </div>
    ))
  }
</div>

<p class="mt-6 text-center text-[13px] text-muted">
  Need Enterprise? <a href="mailto:hello@portix.dev?subject=PortixOne%20Enterprise" class="text-brand hover:underline">Let's talk</a>.
</p>
