---
const cases = [
  {
    id: 'pos',
    label: 'POS',
    printer: 'Thermal receipt printer (ESC/POS)',
    desc: 'Print a receipt the instant a sale closes — no browser dialog between checkout and paper.',
    code: `const portix = new Portix({ appId: 'pos', tenant: 'default' });
await portix.connect();

await portix.print({
  content: 'Coffee    $4.00\\nBurger    $8.00\\nTOTAL     $12.00',
});`,
  },
  {
    id: 'warehouse',
    label: 'Warehouse',
    printer: 'Label printer (ZPL / thermal)',
    desc: 'Print shipping labels straight from your fulfillment dashboard, one per scanned box.',
    code: `const portix = new Portix({ appId: 'warehouse', tenant: 'default' });
await portix.connect();

await portix.print({
  content: 'SKU: SKU-88213\\nDest: DHL Express',
  printerName: 'ZDesigner ZT230',
});`,
  },
  {
    id: 'healthcare',
    label: 'Healthcare',
    printer: 'Wristband / badge printer',
    desc: 'Print a patient wristband at intake without touching hospital IT policy or drivers.',
    code: `const portix = new Portix({ appId: 'healthcare', tenant: 'default' });
await portix.connect();

await portix.print({
  content: 'Patient: PT-4471',
  printerName: 'Zebra HC100',
});`,
  },
];
---

<div class="smart-defaults grid grid-cols-1 gap-10 md:grid-cols-[0.9fr_1.1fr]">
  <div>
    <div class="space-y-2" role="radiogroup" aria-label="Use case">
      {cases.map((c, i) => (
        <button
          type="button"
          role="radio"
          aria-checked={i === 0 ? 'true' : 'false'}
          data-case={c.id}
          class:list={[
            'case-btn flex w-full items-center gap-3 rounded-btn border px-4 py-3 text-left text-[14px] transition-colors duration-150 ease-out',
            i === 0 ? 'is-active border-brand bg-surface text-ink' : 'border-line text-muted hover:border-brand',
          ]}
        >
          <span class:list={['case-dot h-2.5 w-2.5 shrink-0 rounded-full border', i === 0 ? 'border-brand bg-brand' : 'border-line']}></span>
          <span>
            <span class="block font-semibold">{c.label}</span>
            <span class="case-printer block text-[12px] text-muted">{c.printer}</span>
          </span>
        </button>
      ))}
    </div>
    <p class="case-desc mt-5 text-[13px] leading-relaxed text-muted">{cases[0].desc}</p>
  </div>

  <div class="rounded-code border border-line bg-surface-tertiary p-5">
    <pre class="case-code overflow-x-auto font-mono text-[13px] leading-7 text-ink"><code set:html={cases[0].code
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/\b(const|await|new)\b/g, '<span class="text-brand">$1</span>')}
    /></pre>
  </div>
</div>

<script define:vars={{ cases }}>
  const buttons = document.querySelectorAll('.case-btn');
  const descEl = document.querySelector('.case-desc');
  const codeEl = document.querySelector('.case-code code');

  function highlight(code) {
    return code
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/\b(const|await|new)\b/g, '<span class="text-brand">$1</span>');
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.case;
      const active = cases.find((c) => c.id === id);
      if (!active) return;

      buttons.forEach((b) => {
        const dot = b.querySelector('.case-dot');
        b.classList.remove('is-active', 'border-brand', 'bg-surface', 'text-ink');
        b.classList.add('border-line', 'text-muted');
        b.setAttribute('aria-checked', 'false');
        dot?.classList.remove('border-brand', 'bg-brand');
        dot?.classList.add('border-line');
      });
      btn.classList.add('is-active', 'border-brand', 'bg-surface', 'text-ink');
      btn.classList.remove('border-line', 'text-muted');
      btn.setAttribute('aria-checked', 'true');
      btn.querySelector('.case-dot')?.classList.add('border-brand', 'bg-brand');
      btn.querySelector('.case-dot')?.classList.remove('border-line');

      if (descEl) descEl.textContent = active.desc;
      if (codeEl) codeEl.innerHTML = highlight(active.code);
    });
  });
</script>

<script>
  import { markStage } from '../lib/ttfp';

  document.querySelectorAll<HTMLButtonElement>('.case-btn').forEach((btn) => {
    btn.addEventListener('click', () => markStage('selectedUseCase'), { once: true });
  });
</script>
