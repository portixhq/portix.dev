---
const layers = ['Browser', 'Portix runtime', 'Communication layer', 'Drivers'];
const devices = ['Printer', 'USB', 'Serial', 'Bluetooth', 'Future devices'];
---

<div class="flex flex-col items-center">
  {layers.map((layer, i) => (
    <>
      <div
        class:list={[
          'w-56 rounded-md border px-4 py-3 text-center font-mono text-[13px]',
          i === 1 ? 'border-accent2 text-ink' : 'border-line text-ink',
        ]}
      >
        {layer}
      </div>
      <div class="h-7 w-px bg-line"></div>
    </>
  ))}
  <div class="flex flex-wrap justify-center gap-3">
    {devices.map((device, i) => (
      <div
        class:list={[
          'rounded-md border border-line px-4 py-3 font-mono text-[12px]',
          i === devices.length - 1 ? 'text-muted' : 'text-ink',
        ]}
      >
        {device}
      </div>
    ))}
  </div>
</div>
