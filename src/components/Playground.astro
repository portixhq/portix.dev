---
---

<div class="mx-auto grid max-w-4xl grid-cols-1 items-center gap-12 md:grid-cols-2">
  <div class="flex justify-center">
    <div class="playground-receipt-slot relative w-64 overflow-hidden rounded-sm shadow-[0_20px_50px_-15px_rgba(0,0,0,0.35)]">
      <pre
        class="playground-receipt-mono h-[540px] w-64 overflow-y-auto whitespace-pre-wrap break-words bg-white px-5 py-6 font-mono text-[10.5px] leading-[1.55] text-gray-900 transition-transform duration-700 ease-out"
      >══════════════════════════════
         PORTIX.ONE
      FIRST PRINT RECEIPT
══════════════════════════════

Hit print to begin.

══════════════════════════════

Time To First Print
—

Printer
—

Status
waiting for you to hit print…

══════════════════════════════

The first print is the hardest.

The next million are easy.

portix.one
══════════════════════════════</pre>
    </div>
  </div>

  <div class="flex flex-col items-start">
    <p class="mb-2 font-mono text-[12px] font-semibold uppercase tracking-[0.14em] text-brand">Live Runtime check</p>
    <h3 class="font-mono text-2xl font-semibold leading-snug">Hit print. Watch the receipt compose in real time.</h3>
    <p class="mt-3 text-[14px] leading-relaxed text-muted">
      This isn't a mockup — it really looks for a Portix.One Runtime on your machine, no signup required. The receipt
      on the left fills in with the same states your app would see: Runtime found, printer available, paired, job
      accepted, output confirmed.
    </p>

    <div class="mt-6 flex items-center gap-3">
      <button type="button" class="playground-print-btn btn-primary px-7 py-3.5 text-[15px]">
        Print this receipt
      </button>
      <button type="button" class="playground-reset hidden font-mono text-[12px] text-muted underline decoration-line underline-offset-4 hover:text-ink">
        Start a new setup
      </button>
    </div>

    <div class="playground-console mt-5 w-full rounded-md border border-line bg-surface-tertiary p-4 font-mono text-[12px] leading-6 text-muted">
      <p class="console-line text-muted/60">$ waiting for you to hit print…</p>
    </div>

    <div class="playground-outcome mt-4 min-h-[2rem] text-[13px] leading-relaxed"></div>

    <p class="playground-announcer sr-only" aria-live="polite"></p>
  </div>
</div>

<script>
  import { markStage, resetState } from '../lib/ttfp';
  import {
    detectRuntime,
    requestPairing,
    waitForApproval,
    realPrint,
    pollJobStatus,
    PairingExpiredError,
  } from '../lib/runtime-client';

  const btn = document.querySelector<HTMLButtonElement>('.playground-print-btn');
  const resetBtn = document.querySelector<HTMLButtonElement>('.playground-reset');
  const receiptEl = document.querySelector<HTMLPreElement>('.playground-receipt-mono');
  const consoleEl = document.querySelector<HTMLElement>('.playground-console');
  const outcome = document.querySelector<HTMLElement>('.playground-outcome');
  const announcer = document.querySelector<HTMLElement>('.playground-announcer');

  const reducedMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));

  function announce(text: string) {
    if (announcer) announcer.textContent = text;
  }

  function log(line: string): Promise<void> {
    return new Promise((resolve) => {
      const p = document.createElement('p');
      p.className = 'console-line';
      p.textContent = `$ ${line}`;
      consoleEl?.appendChild(p);
      if (consoleEl) consoleEl.scrollTop = consoleEl.scrollHeight;
      setTimeout(resolve, 400);
    });
  }

  function logLive(id: string, line: string): void {
    if (!consoleEl) return;
    let el = consoleEl.querySelector<HTMLElement>(`[data-live="${id}"]`);
    if (!el) {
      el = document.createElement('p');
      el.className = 'console-line';
      el.dataset.live = id;
      consoleEl.appendChild(el);
    }
    el.textContent = `$ ${line}`;
    consoleEl.scrollTop = consoleEl.scrollHeight;
  }

  function resetConsole() {
    if (consoleEl) consoleEl.innerHTML = '';
  }

  function formatElapsed(ms: number): string {
    const totalSec = Math.floor(ms / 1000);
    const m = Math.floor(totalSec / 60);
    const s = totalSec % 60;
    return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
  }

  function center(text: string, width = 30): string {
    const pad = Math.max(0, Math.floor((width - text.length) / 2));
    return ' '.repeat(pad) + text;
  }

  type Phase =
    | 'idle'
    | 'preparing'
    | 'runtimeMissing'
    | 'printerMissing'
    | 'pairing'
    | 'expired'
    | 'jobAccepted'
    | 'simulatedPreview'
    | 'delivered'
    | 'confirmed'
    | 'failed';

  interface ReceiptState {
    phase: Phase;
    elapsedMs: number | null;
    printerName: string | null;
    jobId: string | null;
  }

  // One shared, mutable state object for the whole component's lifetime — the scroll-triggered idle
  // reveal, the reset button, and the click flow all mutate the same reference and call the same
  // `rerender()`, so the render queue (see `renderReceipt` below) always picks up the latest fields
  // no matter which of them last requested a render.
  const state: ReceiptState = { phase: 'idle', elapsedMs: null, printerName: null, jobId: null };
  const rerender = () => renderReceipt(state);

  const BODY_LINES: Record<Phase, string[]> = {
    idle: ['Hit print to begin.'],
    preparing: ['PREPARING…'],
    runtimeMissing: ['Runtime not found on this device.', 'Install it once — this exact', 'receipt prints for real from then on.'],
    printerMissing: ['Runtime is running, but no', 'printer is configured yet.'],
    pairing: ['Waiting for approval in your', 'Portix.One tray…'],
    expired: ['Approval timed out. Hit print', 'again to retry.'],
    jobAccepted: ['Job accepted. Waiting for the', 'Runtime to confirm delivery…'],
    simulatedPreview: [
      'PREVIEW ONLY — this Runtime has',
      'no real printer driver configured.',
      'The wire is proven; connect a',
      'real printer to see paper.',
    ],
    delivered: ['Delivered to the printer. Physical', 'output could not be confirmed', 'from here.'],
    confirmed: [
      'Achievement Unlocked',
      '',
      'Your web app sent a job to a',
      'real local thermal printer.',
      '',
      'No browser print dialog.',
      'No extensions.',
      'No driver-specific app code.',
      'No printer IP in your app.',
      '',
      'JavaScript to paper.',
    ],
    failed: ['Something went wrong on the', 'Runtime side. Try again.'],
  };

  const STATUS_LINE: Record<Phase, string> = {
    idle: 'waiting for you to hit print…',
    preparing: 'PREPARING',
    runtimeMissing: 'RUNTIME NOT FOUND',
    printerMissing: 'NO PRINTER CONFIGURED',
    pairing: 'PENDING APPROVAL',
    expired: 'APPROVAL EXPIRED',
    jobAccepted: 'JOB ACCEPTED',
    simulatedPreview: 'PREVIEW ONLY',
    delivered: 'DELIVERED TO PRINTER',
    confirmed: 'OUTPUT CONFIRMED',
    failed: 'FAILED',
  };

  function headlineFor(phase: Phase): string {
    if (phase === 'confirmed') return 'FIRST PRINT ACHIEVED';
    if (phase === 'delivered' || phase === 'simulatedPreview') return 'FIRST JOB DELIVERED';
    return 'FIRST PRINT RECEIPT';
  }

  function buildReceipt(state: ReceiptState): string {
    const sep = '═'.repeat(30);
    const lines = [
      sep,
      center('PORTIX.ONE'),
      center(headlineFor(state.phase)),
      sep,
      '',
      ...BODY_LINES[state.phase],
      '',
      sep,
      '',
      'Time To First Print',
      state.elapsedMs === null ? '—' : formatElapsed(state.elapsedMs),
      '',
      'Printer',
      state.printerName ?? '—',
      '',
      'Status',
      STATUS_LINE[state.phase],
      ...(state.jobId ? ['', `Job ${state.jobId}`] : []),
      '',
      sep,
      '',
      'The first print is the hardest.',
      '',
      'The next million are easy.',
      '',
      'portix.one',
      sep,
    ];
    return lines.join('\n');
  }

  // A new state can arrive (a 1s elapsed-time tick, a phase change) while the previous diff is still
  // mid-type. Racing two concurrent diffs against the same DOM text caused the receipt to visibly
  // truncate and re-type — this queue guarantees only one typing loop ever touches the element at a
  // time; anything that arrives while it's running just flags `pending` and gets picked up next pass,
  // always diffed against whatever is actually on screen, so the text only ever moves forward.
  let rendering = false;
  let pending = false;
  let firstReveal = true;

  async function renderReceipt(state: ReceiptState) {
    pending = true;
    if (rendering) return;
    rendering = true;
    try {
      while (pending) {
        pending = false;
        await typeToward(state);
      }
    } finally {
      rendering = false;
    }
  }

  async function typeToward(state: ReceiptState) {
    if (!receiptEl) return;
    const target = buildReceipt(state);
    const current = receiptEl.textContent ?? '';
    if (current === target) return;

    if (reducedMotion()) {
      receiptEl.textContent = target;
      return;
    }

    let commonLen = 0;
    while (commonLen < current.length && commonLen < target.length && current[commonLen] === target[commonLen]) {
      commonLen++;
    }
    const common = target.slice(0, commonLen);
    const added = target.slice(commonLen);

    receiptEl.textContent = common;

    // First reveal gets the full ~2.5-4s "composing" feel; later diffs (status ticks) stay snappy.
    const budgetMs = firstReveal ? 3200 : 900;
    firstReveal = false;
    const perChar = Math.min(22, Math.max(3, budgetMs / Math.max(added.length, 1)));

    for (let i = 0; i < added.length; i++) {
      if (pending) return; // a newer state landed — the outer queue re-diffs against what's on screen now
      receiptEl.textContent += added[i];
      const isSeparatorChar = added[i] === '═';
      await sleep(isSeparatorChar ? perChar * 0.35 : perChar);
    }
  }

  function settle() {
    if (!receiptEl || reducedMotion()) return;
    receiptEl.style.transform = 'translateY(3px) scale(1.01)';
    setTimeout(() => {
      if (receiptEl) receiptEl.style.transform = 'translateY(0) scale(1)';
    }, 260);
  }

  function bump() {
    if (!receiptEl || reducedMotion()) return;
    receiptEl.style.transform = 'translateY(6px) scale(0.98)';
    setTimeout(() => {
      receiptEl.style.transform = 'translateY(0) scale(1)';
    }, 300);
  }

  function showReset() {
    resetBtn?.classList.remove('hidden');
  }

  // Auto-type the idle receipt the first time it scrolls into view, before the visitor ever touches
  // the print button — a teaser of the same real typing engine the click flow uses, not a separate
  // effect. The server-rendered idle text stays in the DOM (crawlable, works with JS disabled or
  // reduced motion); with JS and motion both available, it's cleared and retyped on scroll-in instead
  // of just sitting there fully formed.
  if (receiptEl && !reducedMotion() && 'IntersectionObserver' in window) {
    receiptEl.textContent = '';
    const revealObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            rerender();
            revealObserver.disconnect();
          }
        }
      },
      { threshold: 0.35 },
    );
    revealObserver.observe(receiptEl);
  }

  resetBtn?.addEventListener('click', () => {
    resetState();
    resetConsole();
    if (outcome) outcome.innerHTML = '';
    state.phase = 'idle';
    state.elapsedMs = null;
    state.printerName = null;
    state.jobId = null;
    rerender();
    resetBtn.classList.add('hidden');
    if (btn) {
      btn.disabled = false;
      btn.textContent = 'Print this receipt';
    }
  });

  btn?.addEventListener('click', async () => {
    if (btn.disabled) return;
    btn.disabled = true;
    btn.textContent = 'Working…';
    if (outcome) outcome.innerHTML = '';
    resetConsole();
    bump();

    const startedAt = Date.now();
    const elapsed = () => Date.now() - startedAt;
    // Elapsed time updates only at real milestones, never on a live per-second tick — a ticking clock
    // sitting in the middle of the receipt text would force the diff-typer to truncate and re-type
    // everything after it on every tick, fighting the in-progress typing animation.
    state.phase = 'preparing';
    state.elapsedMs = 0;
    state.printerName = null;
    state.jobId = null;

    // Detection starts immediately and is awaited on its own — the typing animation and the
    // activity log both run in the background, never blocking the real result. Health checks
    // usually resolve in well under a second, far sooner than a ~3s "preparing" typing pass would
    // finish; if the animation is still mid-type when the result lands, the render queue in
    // `renderReceipt` cuts it off cleanly and continues typing straight toward the real state
    // instead of finishing a receipt that's about to be overwritten.
    const detectPromise = detectRuntime();
    rerender();
    log('Detecting Portix.One Runtime…');

    const { found, simulated, defaultPrinter } = await detectPromise;
    state.elapsedMs = elapsed();

    if (!found) {
      state.phase = 'runtimeMissing';
      await log('No Runtime responded.');
      announce('Runtime not found on this device.');
      await rerender();
      if (outcome) {
        outcome.innerHTML = `
          <a href="https://github.com/portixhq/portixone/releases/latest" class="mt-2 inline-block font-semibold text-brand hover:underline">Download Runtime →</a>
        `;
      }
      btn.textContent = 'Print again';
      btn.disabled = false;
      showReset();
      return;
    }

    markStage('runtimeDetected');
    await log(`Runtime found${defaultPrinter ? ` — default printer: ${defaultPrinter}` : ''}.`);
    announce('Runtime found on this device.');

    if (!defaultPrinter) {
      state.phase = 'printerMissing';
      await rerender();
      announce('Runtime is running, but no printer is configured.');
      if (outcome) {
        outcome.innerHTML = `<span class="text-brand font-semibold">No printer configured on this Runtime yet.</span> Set a default printer from the Runtime dashboard, then print again.`;
      }
      btn.textContent = 'Print again';
      btn.disabled = false;
      showReset();
      return;
    }

    markStage('printerAvailable');
    state.printerName = defaultPrinter;
    state.phase = 'pairing';
    state.elapsedMs = elapsed();
    await rerender();
    await log('Printer available. Requesting permission to print…');

    try {
      const { code, expiresAt } = await requestPairing();
      await log(`Check your Portix.One tray — approve code ${code} to continue.`);
      announce(`Pairing requested. Approve code ${code} in your Portix.One tray.`);
      if (outcome) {
        outcome.innerHTML = `<span class="text-brand font-semibold">Waiting for approval in your Portix.One tray… (code: ${code})</span>`;
      }

      const token = await waitForApproval(code, expiresAt, (_elapsed, remaining) => {
        logLive('waiting', `Still waiting for approval in the tray… (${remaining}s left)`);
      });

      markStage('applicationPaired');
      announce('Pairing approved.');
      await log('Approved! Sending the print job…');

      const result = await realPrint(
        token,
        'Coffee    $4.00\nBurger    $8.00\nTOTAL     $12.00\n\nPrinted from portix.one\'s Playground.',
      );
      markStage('jobAccepted');
      state.jobId = result.jobId;
      state.phase = 'jobAccepted';
      state.elapsedMs = elapsed();
      await rerender();
      await log(`Print job ${result.jobId} — ${result.status}.`);
      announce('Job accepted by the Runtime.');

      if (simulated) {
        state.phase = 'simulatedPreview';
        state.elapsedMs = elapsed();
        await rerender();
        announce('Preview only — no real printer driver configured.');
        if (outcome) {
          outcome.innerHTML = `Pairing and the print job both worked for real. This Runtime has no real printer driver configured, so nothing physically printed this time.`;
        }
        settle();
        btn.textContent = 'Print again';
        btn.disabled = false;
        showReset();
        return;
      }

      await log('Waiting for the Runtime to confirm delivery…');
      const terminal = await pollJobStatus(token, result.jobId);
      state.elapsedMs = elapsed();

      if (terminal === 'completed') {
        markStage('printed');
        state.phase = 'confirmed';
        await log('Output confirmed.');
        announce('Output confirmed — check your printer.');
        if (outcome) outcome.innerHTML = `<span class="text-brand font-semibold">Check your printer — that was a real print.</span>`;
        await rerender();
        settle();
      } else if (terminal === 'failed' || terminal === 'cancelled') {
        state.phase = 'failed';
        await log(`Job ${terminal}.`);
        announce(`Print job ${terminal}.`);
        if (outcome) outcome.innerHTML = `The Runtime reported the job as ${terminal}. Try again, or check the Runtime dashboard.`;
        await rerender();
      } else {
        state.phase = 'delivered';
        await log('Delivered to the printer — could not confirm the terminal state in time.');
        announce('Delivered to the printer. Could not confirm final status.');
        if (outcome) outcome.innerHTML = `Delivered to the printer, but we couldn't confirm the terminal status in time. Check the Runtime dashboard for the final result.`;
        await rerender();
      }

      btn.textContent = 'Print again';
    } catch (error) {
      const expired = error instanceof PairingExpiredError;
      state.phase = expired ? 'expired' : 'failed';
      state.elapsedMs = elapsed();
      await log(expired ? 'Approval timed out.' : 'Something went wrong talking to the Runtime.');
      announce(expired ? 'Approval timed out.' : 'Something went wrong talking to the Runtime.');
      await rerender();
      if (outcome) {
        outcome.innerHTML = expired
          ? 'Approval timed out — hit print again and approve it from the tray a little faster.'
          : 'Could not complete a real print this time — try again, or use the Runtime dashboard directly.';
      }
      btn.textContent = 'Try again';
    } finally {
      btn.disabled = false;
      showReset();
    }
  });
</script>
