---
import { frameworks, sdk, docs, LAST_VERIFIED_AT } from '../data/integration-manifest';
import AgentPromptGenerator from './AgentPromptGenerator.astro';

const printerPresets = ['Thermal receipt (default)', 'Epson TM-T88', 'SICAR WL88S'];
const tabs = [
  { id: 'sdk', label: 'SDK' },
  { id: 'framework', label: 'Framework' },
  { id: 'agent', label: 'AI coding agent' },
  { id: 'rest', label: 'REST / Low-code' },
  { id: 'nocode', label: 'No-code preview' },
];
---

<div class="builder-paths mx-auto max-w-4xl rounded-card border border-line bg-surface p-6 md:p-8">
  <p class="mb-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-brand">How are you building?</p>
  <div class="path-tabs mt-3 flex flex-wrap gap-2">
    {tabs.map((t, i) => (
      <button
        type="button"
        class:list={['path-tab rounded-btn border px-3.5 py-2 text-[12.5px] font-medium transition-colors duration-150 ease-out', i === 0 ? 'border-brand bg-brand/10 text-ink' : 'border-line text-muted hover:border-brand hover:text-ink']}
        data-path={t.id}
      >
        {t.label}
      </button>
    ))}
  </div>

  <!-- SDK path -->
  <div class="path-panel mt-8" data-panel="sdk">
    <p class="text-[13px] leading-relaxed text-muted">
      Control pairing, printer selection, job status, and errors directly from your own application code.
    </p>
    <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <label class="text-[12px] text-muted">
        Language
        <select class="sdk-language mt-1 w-full rounded-btn border border-line bg-surface-secondary px-3 py-2 text-[13px] text-ink">
          <option>JavaScript</option>
          <option>TypeScript</option>
        </select>
      </label>
      <label class="text-[12px] text-muted">
        Printer
        <select class="sdk-printer mt-1 w-full rounded-btn border border-line bg-surface-secondary px-3 py-2 text-[13px] text-ink">
          {printerPresets.map((p) => <option>{p}</option>)}
        </select>
      </label>
      <label class="text-[12px] text-muted">
        Mode
        <select class="sdk-mode mt-1 w-full rounded-btn border border-line bg-surface-secondary px-3 py-2 text-[13px] text-ink">
          <option value="mock">Mock (no Runtime needed)</option>
          <option value="runtime">Runtime (real printer)</option>
        </select>
      </label>
    </div>
    <div class="mt-5 rounded-code border border-line bg-surface-tertiary p-5">
      <pre class="sdk-snippet overflow-x-auto font-mono text-[12.5px] leading-6 text-ink"><code></code></pre>
    </div>
    <div class="mt-5 flex flex-wrap items-center gap-3">
      <button type="button" class="sdk-copy btn-primary">Copy code</button>
      <a href={docs.sdkReference} class="btn-link">Read the SDK reference →</a>
    </div>
  </div>

  <!-- Framework path -->
  <div class="path-panel mt-8 hidden" data-panel="framework">
    <p class="text-[13px] leading-relaxed text-muted">
      Framework-shaped code using the same verified SDK calls as the SDK path above.
    </p>
    <div class="mt-5 grid grid-cols-2 gap-2 sm:grid-cols-3">
      {frameworks.map((f) => (
        <button
          type="button"
          class="framework-choice rounded-btn border border-line px-3 py-2.5 text-left text-[12.5px] text-muted transition-colors duration-150 ease-out hover:border-brand hover:text-ink"
          data-framework={f.id}
          data-has-example={f.hasMaintainedExample ? '1' : '0'}
          data-example-url={f.exampleUrl ?? ''}
        >
          <span class="block font-medium text-ink">{f.label}</span>
          <span class="block text-[10.5px] text-muted">{f.hasMaintainedExample ? 'Maintained example' : 'On the roadmap'}</span>
        </button>
      ))}
    </div>
    <div class="mt-5 rounded-code border border-line bg-surface-tertiary p-5">
      <pre class="framework-snippet overflow-x-auto font-mono text-[12.5px] leading-6 text-ink"><code></code></pre>
    </div>
    <p class="framework-note mt-3 text-[12px] leading-relaxed text-muted"></p>
    <div class="mt-4 flex flex-wrap items-center gap-3">
      <button type="button" class="framework-copy btn-primary">Copy code</button>
      <a class="framework-example-link btn-link hidden" href="#" target="_blank" rel="noopener">Open maintained example →</a>
    </div>
  </div>

  <!-- AI coding agent path -->
  <div class="path-panel mt-8 hidden" data-panel="agent">
    <p class="mb-1 font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-brand">AI-assisted integration</p>
    <h3 class="font-mono text-[17px] font-semibold text-ink">Give your coding agent the exact Portix.One context.</h3>
    <p class="mt-3 text-[13px] leading-relaxed text-muted">
      Choose your stack, printer, and protocol. Portix.One generates a complete implementation prompt with the
      correct SDK surface, Runtime requirements, error states, and verification steps.
    </p>
    <div class="mt-5">
      <AgentPromptGenerator />
    </div>
  </div>

  <!-- REST / Low-code path -->
  <div class="path-panel mt-8 hidden" data-panel="rest">
    <p class="text-[13px] leading-relaxed text-muted">
      For teams whose platform can make authenticated HTTP requests and handle responses. REST still requires
      configuration, authentication, and status handling — it is not a no-code path.
    </p>
    <label class="mt-5 block text-[12px] text-muted">
      Printer
      <select class="rest-printer mt-1 w-full max-w-xs rounded-btn border border-line bg-surface-secondary px-3 py-2 text-[13px] text-ink">
        {printerPresets.map((p) => <option>{p}</option>)}
      </select>
    </label>
    <button type="button" class="rest-generate btn-primary mt-4">Generate REST recipe</button>
    <div class="rest-result mt-5 hidden">
      <div class="max-h-96 overflow-y-auto rounded-code border border-line bg-surface-tertiary p-5">
        <pre class="rest-recipe whitespace-pre-wrap font-mono text-[12px] leading-6 text-ink"></pre>
      </div>
      <button type="button" class="rest-copy btn-primary mt-4">Copy recipe</button>
    </div>
  </div>

  <!-- No-code preview path -->
  <div class="path-panel mt-8 hidden" data-panel="nocode">
    <h3 class="font-mono text-[16px] font-semibold text-ink">No-code connector preview</h3>
    <p class="mt-2 text-[13px] leading-relaxed text-muted">
      We are designing a guided Portix.One connector for visual automation tools. Tell us which platform you use
      and which printer workflow you need — no snippets here yet, because the connector doesn't exist yet.
    </p>
    <form class="nocode-form mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <input name="platform" required placeholder="Platform (Zapier, Make, n8n…)" class="rounded-btn border border-line bg-surface px-4 py-2 text-[13px] text-ink placeholder:text-muted focus:border-ink focus-visible:outline-none" />
      <input name="printerModel" placeholder="Printer model" class="rounded-btn border border-line bg-surface px-4 py-2 text-[13px] text-ink placeholder:text-muted focus:border-ink focus-visible:outline-none" />
      <input name="workflow" placeholder="What workflow needs to print?" class="rounded-btn border border-line bg-surface px-4 py-2 text-[13px] text-ink placeholder:text-muted focus:border-ink focus-visible:outline-none sm:col-span-2" />
      <input type="email" name="email" required placeholder="you@company.com" class="rounded-btn border border-line bg-surface px-4 py-2 text-[13px] text-ink placeholder:text-muted focus:border-ink focus-visible:outline-none sm:col-span-2" />
      <button type="submit" class="btn-primary sm:col-span-2">Join connector preview</button>
    </form>
    <p class="nocode-message mt-3 text-[13px] text-muted"></p>
  </div>

  <p class="mt-8 border-t border-line pt-4 text-[11px] text-muted">
    Verified against Portix.One SDK {sdk.latestVerifiedVersion} · manifest last verified {LAST_VERIFIED_AT}
  </p>
</div>

<script>
  import { buildSdkSnippet, buildFrameworkSnippet, buildRestRecipe } from '../lib/integration-prompt';
  import { frameworks } from '../data/integration-manifest';
  import type { FrameworkId } from '../data/integration-manifest';

  const root = document.querySelector<HTMLElement>('.builder-paths');
  if (root) {
    // --- Analytics stub — not wired to a real pipeline yet, kept separate from TTFP on purpose. ---
    function track(event: string, detail: Record<string, unknown> = {}) {
      window.dispatchEvent(new CustomEvent('portix:analytics', { detail: { event, ...detail } }));
    }

    function highlight(code: string) {
      return code
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/\b(import|from|const|await|new|async|function|export|class|return|try|catch|throw|if|let)\b/g, '<span class="text-brand">$1</span>');
    }

    // --- Path tabs ---
    const tabs = root.querySelectorAll<HTMLButtonElement>('.path-tab');
    const panels = root.querySelectorAll<HTMLElement>('.path-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const path = tab.dataset.path!;
        tabs.forEach((t) => {
          const active = t === tab;
          t.classList.toggle('border-brand', active);
          t.classList.toggle('bg-brand/10', active);
          t.classList.toggle('text-ink', active);
          t.classList.toggle('border-line', !active);
          t.classList.toggle('text-muted', !active);
        });
        panels.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== path));
        track('builder_path_selected', { path });
      });
    });

    // --- SDK path ---
    const sdkLanguage = root.querySelector<HTMLSelectElement>('.sdk-language');
    const sdkPrinter = root.querySelector<HTMLSelectElement>('.sdk-printer');
    const sdkMode = root.querySelector<HTMLSelectElement>('.sdk-mode');
    const sdkSnippetEl = root.querySelector<HTMLElement>('.sdk-snippet code');

    function renderSdkSnippet() {
      const code = buildSdkSnippet({
        framework: 'javascript',
        printerName: sdkPrinter?.value.includes('default') ? undefined : sdkPrinter?.value,
        mode: (sdkMode?.value as 'mock' | 'runtime') ?? 'mock',
        appId: 'my-app',
        tenant: 'default',
      });
      if (sdkSnippetEl) sdkSnippetEl.innerHTML = highlight(code);
    }
    [sdkLanguage, sdkPrinter, sdkMode].forEach((el) => el?.addEventListener('change', renderSdkSnippet));
    renderSdkSnippet();

    root.querySelector('.sdk-copy')?.addEventListener('click', () => {
      navigator.clipboard.writeText(sdkSnippetEl?.textContent ?? '');
      track('sdk_snippet_copied');
    });

    // --- Framework path ---
    let selectedFramework: FrameworkId = 'react';
    const frameworkSnippetEl = root.querySelector<HTMLElement>('.framework-snippet code');
    const frameworkNoteEl = root.querySelector<HTMLElement>('.framework-note');
    const frameworkExampleLink = root.querySelector<HTMLAnchorElement>('.framework-example-link');

    function renderFrameworkSnippet() {
      const entry = frameworks.find((f) => f.id === selectedFramework);
      const code = buildFrameworkSnippet({ framework: selectedFramework, mode: 'mock', appId: 'my-app', tenant: 'default' });
      if (frameworkSnippetEl) frameworkSnippetEl.innerHTML = highlight(code);
      if (frameworkNoteEl) {
        frameworkNoteEl.textContent = entry?.hasMaintainedExample
          ? ''
          : (entry?.note ?? 'Maintained example on the roadmap — this snippet uses the same verified SDK calls.');
      }
      if (frameworkExampleLink) {
        if (entry?.hasMaintainedExample && entry.exampleUrl) {
          frameworkExampleLink.href = entry.exampleUrl;
          frameworkExampleLink.classList.remove('hidden');
        } else {
          frameworkExampleLink.classList.add('hidden');
        }
      }
    }
    root.querySelectorAll<HTMLButtonElement>('.framework-choice').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedFramework = btn.dataset.framework as FrameworkId;
        root.querySelectorAll('.framework-choice').forEach((b) => b.classList.toggle('border-brand', b === btn));
        renderFrameworkSnippet();
        track('framework_selected', { framework: selectedFramework });
      });
    });
    renderFrameworkSnippet();

    root.querySelector('.framework-copy')?.addEventListener('click', () => {
      navigator.clipboard.writeText(frameworkSnippetEl?.textContent ?? '');
      track('sdk_snippet_copied', { framework: selectedFramework });
    });
    root.querySelector('.framework-example-link')?.addEventListener('click', () => {
      track('docs_opened_from_generator', { source: 'framework-example' });
    });

    // The AI coding agent panel is a nested <AgentPromptGenerator /> — it wires up its own
    // generate/copy/tab behavior in its own <script>, scoped to `.agent-generator`.

    // --- REST / Low-code path ---
    const restRecipeEl = root.querySelector<HTMLElement>('.rest-recipe');
    const restResult = root.querySelector<HTMLElement>('.rest-result');
    root.querySelector('.rest-generate')?.addEventListener('click', () => {
      const printerType = root.querySelector<HTMLSelectElement>('.rest-printer')?.value ?? 'Thermal receipt';
      const recipe = buildRestRecipe({ printerType });
      if (restRecipeEl) restRecipeEl.textContent = recipe;
      restResult?.classList.remove('hidden');
      track('rest_recipe_generated', { printerType });
    });
    root.querySelector('.rest-copy')?.addEventListener('click', () => {
      navigator.clipboard.writeText(restRecipeEl?.textContent ?? '');
    });

    // --- No-code preview path — reuses the same waitlist backend as the main signup form,
    // mapped onto its existing columns (platform → framework, printerModel → printer, workflow → use_case). ---
    const nocodeForm = root.querySelector<HTMLFormElement>('.nocode-form');
    const nocodeMessage = root.querySelector<HTMLElement>('.nocode-message');
    const supabaseUrl = (import.meta as any).env?.PUBLIC_SUPABASE_URL ?? '';
    const supabaseAnonKey = (import.meta as any).env?.PUBLIC_SUPABASE_ANON_KEY ?? '';

    nocodeForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(nocodeForm);
      const submitBtn = nocodeForm.querySelector('button');
      if (submitBtn) (submitBtn as HTMLButtonElement).disabled = true;
      if (nocodeMessage) nocodeMessage.textContent = 'Joining…';

      if (!supabaseUrl || !supabaseAnonKey) {
        if (nocodeMessage) nocodeMessage.textContent = "The signup form isn't connected yet.";
        if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
        return;
      }

      try {
        const response = await fetch(`${supabaseUrl}/functions/v1/waitlist`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${supabaseAnonKey}` },
          body: JSON.stringify({
            email: data.get('email'),
            framework: data.get('platform'),
            printer: data.get('printerModel'),
            useCase: `No-code connector preview — ${data.get('workflow') ?? ''}`,
          }),
        });
        if (!response.ok) throw new Error('request failed');
        if (nocodeMessage) nocodeMessage.textContent = "You're on the list — we'll reach out about the connector preview.";
        nocodeForm.reset();
        track('no_code_preview_joined');
      } catch {
        if (nocodeMessage) nocodeMessage.textContent = 'Could not save your signup — please try again.';
      } finally {
        if (submitBtn) (submitBtn as HTMLButtonElement).disabled = false;
      }
    });
  }
</script>
