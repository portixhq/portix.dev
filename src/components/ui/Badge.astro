---
interface Props {
  variant?: 'default' | 'success' | 'warning' | 'danger';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const variantClass = {
  default: 'border-line text-muted',
  success: 'border-brand text-ink',
  warning: 'border-warning text-warning',
  danger: 'border-danger text-danger',
}[variant];
---

<span
  class:list={[
    'inline-flex items-center gap-1.5 rounded-full border px-3 py-1 font-mono text-[12px] font-medium uppercase tracking-wide',
    variantClass,
    className,
  ]}
>
  <slot />
</span>
