---
interface Props {
  type?: string;
  name?: string;
  id?: string;
  placeholder?: string;
  required?: boolean;
  value?: string;
  class?: string;
}

const {
  type = 'text',
  name,
  id,
  placeholder,
  required = false,
  value,
  class: className,
} = Astro.props;
---

<input
  type={type}
  name={name}
  id={id}
  placeholder={placeholder}
  required={required}
  value={value}
  class:list={[
    'w-full rounded-btn border border-line bg-surface px-4 py-2 font-sans text-[14px] text-ink placeholder:text-muted transition-colors duration-150 ease-out focus:border-ink focus-visible:outline-none',
    className,
  ]}
/>
