---
interface Props {
  cols?: 2 | 3 | 4;
  class?: string;
}

const { cols = 3, class: className } = Astro.props;

const colsClass = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-4',
}[cols];
---

<div class:list={['grid grid-cols-1 gap-6', colsClass, className]}>
  <slot />
</div>
