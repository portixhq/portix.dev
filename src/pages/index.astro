---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalInstall from '../components/TerminalInstall.astro';
import TTFPBar from '../components/TTFPBar.astro';
import StuckHereDiagram from '../components/StuckHereDiagram.astro';
import SmartDefaults from '../components/SmartDefaults.astro';
import Playground from '../components/Playground.astro';
import SnippetWizard from '../components/SnippetWizard.astro';
import ReadyChecklist from '../components/ReadyChecklist.astro';
import InstallChecklist from '../components/InstallChecklist.astro';
import CostOfProblem from '../components/CostOfProblem.astro';
import LossAversion from '../components/LossAversion.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CompatibilityGrid from '../components/CompatibilityGrid.astro';
import OpenSourceLinks from '../components/OpenSourceLinks.astro';
import DocsCards from '../components/DocsCards.astro';
import PricingCards from '../components/PricingCards.astro';
import StatusRoadmap from '../components/StatusRoadmap.astro';
import JoinPreviewForm from '../components/JoinPreviewForm.astro';

const badges = ['Windows Ready', 'Local Runtime', 'Secure Pairing', 'Thermal Printers', 'ESC/POS', 'REST', 'WebSocket'];
---

<BaseLayout title="Print from any web app">
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pb-20 pt-20 text-center md:pt-28">
    <div class="mb-5 flex flex-wrap items-center justify-center gap-3">
      <span class="rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.1em] text-accent">
        Developer Preview
      </span>
      <span class="text-[11px] text-muted">Early Access • Windows • ESC/POS</span>
    </div>

    <h1 class="text-[36px] font-extrabold leading-[1.15] tracking-tight md:text-[48px]">
      Printing from a web app shouldn't be the hardest part of your stack.
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-[17px] leading-relaxed text-muted">
      Connect any local printer to your web application in minutes. No drivers. No browser hacks. No manual configuration.
    </p>

    <div class="mx-auto mt-8 max-w-md">
      <TerminalInstall command="npm install @portixone/sdk" />
    </div>

    <div class="mt-5 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[11px] text-muted">
      {badges.map((b) => (
        <span class="flex items-center gap-1.5">
          <span class="text-accent">✓</span>
          {b}
        </span>
      ))}
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="#playground" class="rounded-md bg-accent px-6 py-3 text-[14px] font-semibold text-[#00202A] hover:opacity-90">
        Start printing in under 5 minutes
      </a>
      <a href="#playground" class="rounded-md border border-line px-6 py-3 text-[14px] font-semibold hover:border-white/20">
        Watch it print in 30 seconds
      </a>
    </div>
  </section>

  <!-- Most developers get stuck here -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-10 text-center text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Most developers get stuck here</p>
      <StuckHereDiagram />
    </div>
  </section>

  <!-- Smart Defaults -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-10 text-center text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Pick your use case</p>
      <SmartDefaults />
    </div>
  </section>

  <!-- Playground -->
  <section id="playground" class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <Playground />
    </div>
  </section>

  <!-- IKEA-effect wizard -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 text-center text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Build your integration</p>
      <h2 class="mb-10 text-center text-2xl font-semibold">Four clicks to your own snippet.</h2>
      <SnippetWizard />
    </div>
  </section>

  <!-- Ready checklist -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <ReadyChecklist />
    </div>
  </section>

  <!-- Install checklist with ETA -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <InstallChecklist />
    </div>
  </section>

  <!-- Comparison + Compatibility -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-8 text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Browser printing vs. PortixOne</p>
      <ComparisonTable />
    </div>
  </section>

  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-8 text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Compatibility</p>
      <CompatibilityGrid />
    </div>
  </section>

  <!-- Loss aversion -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <LossAversion />
    </div>
  </section>

  <!-- Cost of problem + Pricing (contrast effect) -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <CostOfProblem />
      <div class="mt-16 border-t border-line pt-16">
        <p class="mb-3 text-center text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Pricing</p>
        <h2 class="text-center text-2xl font-semibold">The SDK stays free. Pricing kicks in once PortixOne is already part of your workflow.</h2>
        <div class="mt-10">
          <PricingCards />
        </div>
      </div>
    </div>
  </section>

  <!-- Open source -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-8 text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Open source</p>
      <OpenSourceLinks />
    </div>
  </section>

  <!-- Documentation -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-8 text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Documentation</p>
      <DocsCards />
    </div>
  </section>

  <!-- Join -->
  <section id="join" class="border-t border-line">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Developer Preview</p>
      <h2 class="text-2xl font-semibold">Tell us about your use case — we'll reach out directly, no sales pitch.</h2>
      <div class="mt-8 max-w-xl">
        <JoinPreviewForm />
      </div>
    </div>
  </section>

  <!-- Status -->
  <section class="border-t border-line pb-16">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-8 text-[12px] font-semibold uppercase tracking-[0.14em] text-accent">Current status</p>
      <div class="max-w-md">
        <StatusRoadmap />
      </div>
    </div>
  </section>

  <TTFPBar />
</BaseLayout>

<style is:global>
  body {
    padding-bottom: 44px;
  }
</style>
