---
import BaseLayout from '../../layouts/BaseLayout.astro';

const options = [
  { name: 'mode', type: '"runtime" | "mock"', default: '"runtime"', desc: '"mock" needs no runtime and no printer' },
  { name: 'apiKey', type: 'string', default: '"dev-local-key"', desc: "Must match the runtime's PORTIX_LOCAL_API_KEY — only needed until pair() is used" },
  { name: 'host', type: 'string', default: '"127.0.0.1"', desc: 'Runtime host' },
  { name: 'port', type: 'number', default: '17321', desc: 'Runtime port' },
  { name: 'appId', type: 'string', default: '—', desc: "Your integration's identity. Required for pair()" },
  { name: 'tenant', type: 'string', default: '—', desc: 'The specific business/customer this connection is for. Required for pair()' },
];

const methods = [
  {
    sig: 'portix.connect(): Promise<void>',
    desc: "Verifies the runtime is reachable (skipped entirely in mock mode). Throws if it isn't — call this before any other method.",
  },
  {
    sig: 'portix.disconnect(): Promise<void>',
    desc: "Ends the SDK session: stops any in-flight pairing poll, closes the live-events socket if one was opened, and drops the connection. Doesn't affect the pairing itself.",
  },
  {
    sig: 'portix.print({ content, printerName?, copies? }): Promise<{ jobId, status, message? }>',
    desc: 'Sends a print job. status is "pending" right after this call resolves — the job is processed asynchronously. See on() below to follow it to "printing"/"completed"/"failed".',
  },
  {
    sig: 'portix.getStatus(): Promise<{ status, version, defaultPrinter? }>',
    desc: "Reads the runtime's health endpoint (or a static mock status in mock mode).",
  },
  {
    sig: 'portix.ping(): Promise<{ pong: boolean }>',
    desc: 'A cheaper liveness check than getStatus() — no version/printer info, just "is it up".',
  },
  {
    sig: 'portix.listPrinters(): Promise<PrinterInfo[]>',
    desc: 'Every printer the runtime can see, with { name, driver?, port?, status?, online }. Empty array in mock mode.',
  },
  {
    sig: 'portix.getPrinter(name): Promise<PrinterInfo>',
    desc: 'Same shape as one entry from listPrinters(). Throws PRINTER_NOT_FOUND if it doesn\'t exist.',
  },
  {
    sig: 'portix.getJobs(): Promise<JobRecord[]>',
    desc: "Every job this connection is allowed to see — all jobs for the admin key, only this tenant/app's own jobs once paired.",
  },
  {
    sig: 'portix.cancel(jobId): Promise<{ jobId, status, message? }>',
    desc: 'Cancels a job that hasn\'t started printing yet. Throws JOB_NOT_CANCELLABLE if it\'s already printing/completed/failed/cancelled.',
  },
  {
    sig: 'portix.pair(): Promise<{ code, expiresAt }>',
    desc: 'Requests pairing for this { tenant, appId } and returns a short code for a human to approve locally on the runtime. Requires tenant/appId in the constructor options.',
  },
  {
    sig: 'portix.on(event, handler): () => void',
    desc: 'Subscribes to real-time events pushed by the runtime — "status", "job:queued", "job:printing", "job:printed", "job:error", "job:cancelled" — plus the SDK-local "paired" event. Returns an unsubscribe function.',
  },
  {
    sig: 'portix.getMetrics(): Promise<RuntimeMetrics>',
    desc: 'Job counts/durations, pairing duration, and WebSocket disconnects. Named honestly — totalDisconnects counts disconnects, not successful reconnections, since reconnect-on-drop isn\'t built yet. Requires the admin key.',
  },
];
---

<BaseLayout title="SDK Reference">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <p class="font-mono text-[12px] font-semibold uppercase tracking-[0.14em] text-brand">Docs</p>
    <h1 class="mt-2 font-mono text-3xl font-semibold">SDK Reference</h1>
    <p class="mt-4 text-ink">
      <code class="font-mono text-[13px]">@portixone/sdk</code> — one class, <code class="font-mono text-[13px]">Portix</code>.
      Source: <a href="https://github.com/portixhq/portixone/tree/master/sdk-js" class="text-brand hover:underline">sdk-js/</a>.
    </p>

    <h2 class="mt-10 font-mono text-lg font-semibold">new Portix(options?)</h2>
    <div class="mt-4 overflow-x-auto rounded-code border border-line">
      <table class="w-full text-left text-[13px]">
        <thead class="border-b border-line bg-surface text-muted">
          <tr>
            <th class="px-4 py-2 font-medium">Option</th>
            <th class="px-4 py-2 font-medium">Type</th>
            <th class="px-4 py-2 font-medium">Default</th>
            <th class="px-4 py-2 font-medium">Description</th>
          </tr>
        </thead>
        <tbody>
          {options.map((opt) => (
            <tr class="border-b border-line last:border-0">
              <td class="px-4 py-3 font-mono text-ink">{opt.name}</td>
              <td class="px-4 py-3 font-mono text-muted">{opt.type}</td>
              <td class="px-4 py-3 font-mono text-muted">{opt.default}</td>
              <td class="px-4 py-3 text-muted">{opt.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2 class="mt-12 font-mono text-lg font-semibold">Methods</h2>
    <div class="mt-6 space-y-6">
      {methods.map((m) => (
        <div class="border-l-2 border-line pl-5">
          <p class="font-mono text-[13px] text-brand">{m.sig}</p>
          <p class="mt-2 text-[13px] leading-relaxed text-muted">{m.desc}</p>
        </div>
      ))}
    </div>

    <h2 class="mt-12 font-mono text-lg font-semibold">Mock mode</h2>
    <p class="mt-4 text-[14px] leading-relaxed text-muted">
      No runtime or printer nearby? Pass <code class="font-mono text-ink">mode: "mock"</code> and use the exact same API —
      <code class="font-mono text-ink">print()</code> renders a text preview instead of sending it anywhere. Going to
      production is a one-word change: drop the option, or set it to <code class="font-mono text-ink">"runtime"</code>.
    </p>

    <h2 class="mt-12 font-mono text-lg font-semibold">Pairing — for multi-tenant integrations</h2>
    <p class="mt-4 text-[14px] leading-relaxed text-muted">
      If you're building a product other businesses install PortixOne for, don't share the runtime's admin key —
      pair each installation once instead:
    </p>
    <pre class="mt-4 overflow-x-auto rounded-code border border-line bg-surface-tertiary p-5 font-mono text-[13px] leading-7 text-ink"><code>{`const portix = new Portix({ tenant: "acme-cafe", appId: "kubia" });
await portix.connect();

const { code } = await portix.pair();
// Show \`code\` to whoever is at the machine — they approve it locally.

portix.on("paired", ({ deviceId, permissions }) => {
  // print()/getJobs()/cancel() are now scoped to this tenant/app.
});`}</code></pre>

    <p class="mt-10 text-sm text-muted">
      See <a href="/docs/runtime" class="text-brand hover:underline">Runtime API</a> if you need to call the local
      HTTP/WebSocket surface directly instead of through the SDK.
    </p>
  </section>
</BaseLayout>
